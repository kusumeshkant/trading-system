# ─── APP ───────────────────────────────────────────
APP_ENV=development          # development | paper | live
APP_NAME=TradingSystem
APP_PORT=8000
SECRET_KEY=change_this_secret_key

# ─── DATABASE ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/trading_db
REDIS_URL=redis://localhost:6379/0

# ─── BINANCE ───────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TESTNET=true         # true for paper trading

# ─── ANGEL ONE ─────────────────────────────────────
ANGELONE_API_KEY=your_angelone_api_key
ANGELONE_CLIENT_ID=your_client_id
ANGELONE_PASSWORD=your_password
ANGELONE_TOTP_SECRET=your_totp_secret

# ─── TELEGRAM ALERTS ───────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ─── RISK LIMITS ───────────────────────────────────
MAX_DAILY_LOSS_PERCENT=5.0   # kill switch triggers at 5% daily loss
MAX_POSITION_SIZE_PERCENT=10.0
MAX_OPEN_TRADES=3
DEFAULT_LEVERAGE=5           # never exceed this

# ─── EMAIL REPORTS (optional) ──────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_TO=recipient@gmail.com

# ─── LOGGING ───────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=app/logs/trading.log
